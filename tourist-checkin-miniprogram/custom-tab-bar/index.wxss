.tab-item-center {
  position: relative;
  top: -20rpx;
}

.publish-btn {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #FFFFFF;
  padding: 6rpx;
  box-shadow: 0 4rpx 20rpx rgba(251, 114, 153, 0.25);
}

.publish-btn-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: linear-gradient(135deg, #FB7299, #FF9AB5);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.4);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.tab-item-center:active .publish-btn-inner {
  transform: scale(0.9);
  box-shadow: 0 2rpx 8rpx rgba(251, 114, 153, 0.3);
}

.tab-label-publish {
  margin-top: 8rpx;
  color: #FB7299;
  font-weight: 600;
}
