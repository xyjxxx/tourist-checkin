.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-inner {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  justify-content: space-around;
  height: 110rpx;
  padding: 0 8rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 6rpx;
  position: relative;
  transition: all 0.2s ease;
}

.tab-item:active {
  transform: scale(0.9);
}

.tab-icon-wrap {
  position: relative;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-dot {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #FB7299;
  animation: dot-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes dot-pop {
  0% { transform: translateX(-50%) scale(0); }
  100% { transform: translateX(-50%) scale(1); }
}

.tab-label {
  font-size: 20rpx;
  color: #AEAEB2;
  margin-top: 4rpx;
  font-weight: 500;
  transition: color 0.2s ease;
}

.tab-item.active .tab-label {
  color: #FB7299;
  font-weight: 600;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: all 0.2s ease;
}

