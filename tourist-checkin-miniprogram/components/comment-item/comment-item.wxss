.comment-container {
  display: flex;
  flex-direction: row;
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--border-light);
  gap: var(--space-sm);
}

.comment-container:last-child {
  border-bottom: none;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--bg);
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-xs);
}

.username {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 600;
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.7;
  margin-bottom: var(--space-12);
  display: block;
}

.comment-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: var(--radius-md);
  min-height: 64rpx;
  transition: all var(--anim-fast) ease;
}

.action-btn:active {
  background: var(--bg);
}

.action-icon {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.action-icon.liked {
  color: var(--danger);
}

.action-count {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.action-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== 嵌套回复 ===== */

.replies-area {
  margin-top: var(--space-xs);
  padding-left: var(--space-md);
  border-left: 4rpx solid var(--primary-light);
}

.reply-item {
  display: flex;
  flex-direction: row;
  padding: var(--space-12) 0;
  gap: var(--space-xs);
  border-bottom: 1rpx solid var(--border-light);
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--bg);
}

.reply-body {
  flex: 1;
  min-width: 0;
}

.reply-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: 4rpx;
}

.reply-username {
  font-size: 24rpx;
  color: var(--text);
  font-weight: 600;
}

.reply-arrow {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.reply-to-name {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 500;
}

.reply-content {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.6;
  display: block;
}
