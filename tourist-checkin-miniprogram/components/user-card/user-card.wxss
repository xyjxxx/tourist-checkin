.user-container {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--space-20) var(--space-md);
  background-color: var(--white);
  border-bottom: 1rpx solid var(--border-light);
  transition: background-color var(--anim-fast) ease;
}

.user-container:active {
  background-color: var(--bg);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: var(--space-sm);
  flex-shrink: 0;
  background: var(--bg);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.username {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.follow-btn {
  padding: 10rpx 28rpx;
  border-radius: var(--radius-xl);
  background: var(--primary);
  flex-shrink: 0;
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.follow-btn:active {
  transform: scale(0.95);
}

.follow-btn text {
  font-size: 24rpx;
  color: var(--primary-foreground);
}

.follow-btn.following {
  background-color: var(--bg);
}

.follow-btn.following text {
  color: var(--text-secondary);
}
