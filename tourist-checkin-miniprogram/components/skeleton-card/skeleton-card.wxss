.skeleton-list {
  padding: 0 var(--space-md);
}

/* ===== Shared ===== */

.skeleton {
  background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--border-light) 50%, var(--bg-secondary) 75%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: var(--radius-sm);
}

.sk-line {
  height: 24rpx;
}

.sk-w30 { width: 30%; }
.sk-w40 { width: 40%; }
.sk-w50 { width: 50%; }
.sk-w60 { width: 60%; }
.sk-w70 { width: 70%; }
.sk-w80 { width: 80%; }
.sk-w90 { width: 90%; }

.sk-mt { margin-top: var(--space-xs); }
.sk-mt-lg { margin-top: var(--space-sm); }

.sk-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sk-avatar-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sk-footer {
  display: flex;
  gap: 40rpx;
}

/* ===== Checkin Skeleton ===== */

.skeleton-checkin {
  background: var(--white);
  border-radius: var(--radius-xl);
  padding: var(--space-md);
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
}

.sk-header {
  display: flex;
  align-items: center;
  gap: var(--space-20);
}

.sk-info {
  flex: 1;
}

.sk-image {
  width: 100%;
  height: 240rpx;
  border-radius: var(--radius-md);
}

.sk-action {
  width: 120rpx;
  height: 40rpx;
  border-radius: var(--radius-lg);
}

/* ===== Note Skeleton ===== */

.skeleton-note {
  background: var(--white);
  border-radius: var(--radius-xl);
  overflow: hidden;
  margin-bottom: var(--space-sm);
  box-shadow: var(--shadow-card);
}

.sk-note-cover {
  width: 100%;
  height: 300rpx;
}

.sk-note-body {
  padding: var(--space-20);
}

.sk-tag {
  width: 100rpx;
  height: 32rpx;
  border-radius: var(--radius-full);
}

/* ===== User Skeleton ===== */

.skeleton-user {
  display: flex;
  align-items: center;
  padding: var(--space-20) var(--space-md);
  background: var(--white);
  border-bottom: 1rpx solid var(--border-light);
  gap: var(--space-sm);
}

.sk-btn {
  width: 120rpx;
  height: 48rpx;
  border-radius: var(--radius-xl);
  flex-shrink: 0;
}

/* ===== Notification Skeleton ===== */

.skeleton-notification {
  display: flex;
  align-items: center;
  padding: var(--space-md);
  background: var(--white);
  border-bottom: 1rpx solid var(--border-light);
  gap: var(--space-sm);
}

@media (prefers-reduced-motion: reduce) {
  .skeleton {
    animation-duration: 0.01ms !important;
  }
}
