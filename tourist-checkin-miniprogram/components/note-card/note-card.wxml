<view class="card-container">
  <image class="cover-image" src="{{note.coverImage}}" mode="aspectFill"></image>
  <view class="card-body">
    <text class="note-title">{{note.title}}</text>
    <view class="author-row">
      <image class="author-avatar" src="{{note.authorAvatar}}" mode="aspectFill"></image>
      <text class="author-name">{{note.authorName}}</text>
    </view>
    <view class="card-footer">
      <text class="city-tag" wx:if="{{note.city}}">{{note.city}}</text>
      <view class="stats">
        <text class="stat">👁 {{note.viewCount || 0}}</text>
        <text class="stat">♥ {{note.likeCount || 0}}</text>
      </view>
    </view>
  </view>
</view>
