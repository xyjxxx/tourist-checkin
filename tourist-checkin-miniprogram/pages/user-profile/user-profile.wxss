.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.profile-header {
  position: relative;
  padding-bottom: 40rpx;
}

.bg-area {
  height: 240rpx;
  background: var(--primary-gradient);
  overflow: hidden;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -80rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 6rpx solid var(--white);
  background-color: var(--bg);
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-top: var(--space-sm);
}

.user-bio {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: var(--space-xs);
}

.stats-row {
  display: flex;
  flex-direction: row;
  background-color: var(--white);
  padding: var(--space-md) 0;
  margin-bottom: var(--space-sm);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.follow-area {
  padding: 0 var(--space-xl) var(--space-md);
  background-color: var(--white);
  margin-bottom: var(--space-sm);
}

.follow-btn {
  width: 100%;
  height: 76rpx;
  background-color: var(--primary);
  color: var(--white);
  font-size: 28rpx;
  border-radius: 38rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.follow-btn::after {
  border: none;
}

.follow-btn.following {
  background-color: var(--white);
  color: var(--text-secondary);
  border: 1rpx solid var(--border);
}

.section-header {
  background-color: var(--white);
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--bg);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.checkin-list {
  background-color: var(--white);
}

.checkin-item {
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--bg);
}

.checkin-item:last-child {
  border-bottom: none;
}

.checkin-content {
  margin-bottom: var(--space-12);
}

.content-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.checkin-images {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-12);
}

.checkin-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-sm);
}

.checkin-meta {
  display: flex;
  align-items: center;
}

.checkin-time {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-right: var(--space-sm);
}

.checkin-location {
  font-size: 22rpx;
  color: var(--primary);
  background-color: var(--primary-light);
  padding: 4rpx var(--space-12);
  border-radius: var(--radius-sm);
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  background-color: var(--white);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.no-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 24rpx;
  color: var(--text-secondary);
}
