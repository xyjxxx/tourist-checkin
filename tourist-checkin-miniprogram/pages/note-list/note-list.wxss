.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* ============================================================
   TABS BAR
   ============================================================ */
.tabs-bar {
  background: var(--white);
  padding: var(--space-sm) var(--space-md);
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: var(--shadow-sm);
}

.tabs-inner {
  display: flex;
  background: var(--bg);
  border-radius: var(--radius-full);
  padding: var(--space-2xs);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2xs);
  padding: var(--space-sm) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-full);
  transition: all var(--anim-fast) var(--ease-out);
}

.tab-item.active {
  background: var(--white);
  color: var(--primary);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

.tab-icon {
  font-size: 24rpx;
}

/* ====== Tab Switch Animation ====== */
.tab-enter {
  animation: fade-in-up var(--anim-fast) var(--ease-out) both;
}

.tab-exit {
  opacity: 0.5;
  transform: translateY(8rpx);
  transition: all 150ms ease;
}

/* ============================================================
   NOTE CARD
   ============================================================ */
.note-list {
  padding: var(--space-sm) var(--space-md);
}

.note-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-md);
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all var(--anim-fast) ease;
}

.note-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

/* ====== Cover ====== */
.note-cover-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
}

.note-cover {
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  bottom: var(--space-sm);
  left: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-2xs);
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

.badge-icon {
  font-size: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* ====== Body ====== */
.note-body {
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.note-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.note-author {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--bg);
  flex-shrink: 0;
}

.author-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.note-stats {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  padding-top: var(--space-xs);
  border-top: 1rpx solid var(--border-light);
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.stat-icon {
  font-size: 22rpx;
}

.stat-num {
  font-size: 22rpx;
  color: var(--text-tertiary);
  font-weight: 500;
}

/* ============================================================
   EMPTY STATE
   ============================================================ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx var(--space-xl) 0;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.empty-emoji {
  font-size: 96rpx;
  z-index: 1;
}

.empty-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.12;
}

.circle-1 {
  width: 180rpx;
  height: 180rpx;
  background: var(--primary);
  top: 10rpx;
  left: 10rpx;
  animation: float-circle 3s ease-in-out infinite;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary);
  bottom: 0;
  right: 0;
  animation: float-circle 3s ease-in-out infinite 1s;
}

@keyframes float-circle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: var(--space-xs);
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: var(--space-lg);
}

.empty-btn {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-xl);
  background: var(--primary-gradient-deep);
  border-radius: var(--radius-full);
  box-shadow: var(--primary-glow);
  transition: all var(--anim-fast) ease;
}

.empty-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.empty-btn-icon {
  font-size: 28rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* ============================================================
   LOADING & NO MORE
   ============================================================ */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: var(--space-sm);
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
  gap: var(--space-sm);
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-xl);
  gap: var(--space-sm);
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}
