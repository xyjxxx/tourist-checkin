.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
  background-color: var(--bg);
  padding-top: 160rpx;
  position: relative;
  overflow: hidden;
}

/* Background decorations */
.bg-deco {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.bg-deco-1 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(251, 114, 153, 0.12), transparent 70%);
  top: -100rpx;
  right: -80rpx;
  animation: float-up 6s ease-in-out infinite;
}

.bg-deco-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(251, 114, 153, 0.06), transparent 70%);
  bottom: -150rpx;
  left: -120rpx;
  animation: float-up 8s ease-in-out infinite 2s;
}

.bg-deco-3 {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 154, 181, 0.1), transparent 70%);
  top: 30%;
  left: -60rpx;
  animation: float-up 7s ease-in-out infinite 1s;
}

.bg-deco-4 {
  width: 150rpx;
  height: 150rpx;
  background: radial-gradient(circle, rgba(255, 182, 200, 0.08), transparent 70%);
  top: 50%;
  right: -40rpx;
  animation: float-up 5s ease-in-out infinite 3s;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
  position: relative;
  z-index: 1;
}

.logo-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 40rpx;
  overflow: hidden;
  margin-bottom: var(--space-md);
  box-shadow: 0 16rpx 48rpx rgba(251, 114, 153, 0.3);
  animation: pulse-glow 3s ease-in-out infinite;
}

.logo-img {
  width: 100%;
  height: 100%;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: var(--space-xs);
  letter-spacing: 2rpx;
}

.app-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  text-align: center;
  padding: 0 48rpx;
  line-height: 1.8;
}

.form-card {
  width: 100%;
  padding: var(--space-lg) var(--space-xl) var(--space-md);
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  border-radius: var(--radius-2xl);
  border: 1rpx solid rgba(251, 114, 153, 0.08);
}

.input-group {
  margin-bottom: var(--space-md);
}

.input-hint {
  display: block;
  font-size: 22rpx;
  color: var(--warning, #FF9500);
  margin-top: var(--space-xs);
  padding-left: var(--space-xs);
}

.input-wrapper {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: var(--white, #FFFFFF);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  padding: 0 var(--space-md);
  height: 96rpx;
  transition: all var(--anim-fast) ease;
}

.input-wrapper:focus-within {
  border-color: var(--primary);
  box-shadow: 0 0 0 4rpx rgba(251, 114, 153, 0.1);
}

.input-prefix {
  font-size: 32rpx;
  margin-right: var(--space-sm);
  opacity: 0.6;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: var(--text);
  background: transparent;
}

.placeholder-style {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.submit-btn {
  width: 100%;
  height: 100rpx;
  background: var(--primary-gradient-deep);
  border-radius: 50rpx;
  border: none;
  color: var(--white);
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(251, 114, 153, 0.35);
  transition: all var(--anim-fast) ease;
  letter-spacing: 4rpx;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(251, 114, 153, 0.3);
}

.btn-loading {
  opacity: 0.85;
}

.submit-btn::after {
  border: none;
}

.switch-area {
  margin-top: 36rpx;
  text-align: center;
  padding: var(--space-sm) 0;
}

.switch-text {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

.forgot-area {
  text-align: center;
  padding: var(--space-sm) 0;
}

.forgot-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.login-success-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}
