.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding: var(--space-sm);
  padding-bottom: env(safe-area-inset-bottom);
}

.achievement-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.achievement-item {
  width: calc(50% - var(--space-xs));
  background-color: var(--white);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.achievement-item.locked {
  opacity: 0.7;
}

.badge-area {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background-color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-12);
}

.locked .badge-area {
  background-color: var(--bg);
}

.badge-icon {
  font-size: var(--space-xl);
}

.badge-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: var(--space-xs);
  text-align: center;
}

.locked .badge-name {
  color: var(--text-secondary);
}

.badge-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: var(--space-12);
  line-height: 1.4;
}

.progress-bar {
  width: 100%;
  height: var(--space-xs);
  background-color: var(--bg);
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-bottom: var(--space-xs);
}

.progress-fill {
  height: 100%;
  background-color: var(--primary);
  border-radius: var(--radius-sm);
  transition: width var(--anim-fast) ease;
}

.progress-text {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.unlocked-text {
  font-size: 22rpx;
  color: var(--primary);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.unlock-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.unlock-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--white);
  border-radius: var(--space-lg);
  padding: var(--space-xl);
  gap: var(--space-20);
}

.unlock-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.unlock-name {
  font-size: 28rpx;
  color: var(--text);
}
