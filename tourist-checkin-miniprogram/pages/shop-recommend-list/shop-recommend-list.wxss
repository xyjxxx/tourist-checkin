.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ===== Page Header ===== */
.page-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 280rpx;
  background: var(--primary-gradient-deep);
  border-radius: 0 0 var(--radius-2xl) var(--radius-2xl);
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xl) var(--space-md) var(--space-md);
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

.header-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.header-action {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  padding: var(--space-12) var(--space-md);
  border-radius: var(--radius-full);
  transition: all var(--anim-fast) ease;
}

.header-action:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.3);
}

.action-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
}

.action-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== Filter Tabs ===== */
.filter-tabs {
  position: relative;
  display: flex;
  gap: var(--space-sm);
  padding: 0 var(--space-md) var(--space-md);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-tabs::-webkit-scrollbar {
  display: none;
}

.filter-tab {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-12) var(--space-md);
  border-radius: var(--radius-full);
  background: var(--white);
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  box-shadow: var(--shadow-sm);
  transition: all var(--anim-fast) ease;
  flex-shrink: 0;
}

.filter-tab.active {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.3);
}

.filter-tab:active {
  transform: scale(0.95);
}

.tab-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot-approved {
  background: var(--success);
}

.dot-pending {
  background: var(--warning);
}

.dot-rejected {
  background: var(--danger);
}

.filter-tab.active .tab-dot {
  background: rgba(255, 255, 255, 0.8);
}

/* ===== List ===== */
.list {
  padding: var(--space-sm) var(--space-md);
}

/* ===== Recommend Card ===== */
.recommend-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-card);
  overflow: hidden;
  transition: transform var(--anim-fast) ease, box-shadow var(--anim-fast) ease;
}

.recommend-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.card-body {
  display: flex;
  padding: var(--space-md);
  gap: var(--space-md);
}

.card-thumb-wrap {
  position: relative;
  flex-shrink: 0;
}

.card-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: var(--radius-lg);
  background: var(--bg);
}

.card-thumb-count {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
}

.count-icon {
  font-size: 18rpx;
}

.count-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

.card-content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-sm);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== Status Badge ===== */
.status-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
  white-space: nowrap;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.status-pending {
  background: var(--warning-subtle);
  color: var(--warning);
}

.status-pending .status-dot {
  background: var(--warning);
  animation: pulse-dot 1.5s ease-in-out infinite;
}

.status-approved {
  background: var(--success-subtle);
  color: var(--success);
}

.status-approved .status-dot {
  background: var(--success);
}

.status-rejected {
  background: var(--danger-subtle);
  color: var(--danger);
}

.status-rejected .status-dot {
  background: var(--danger);
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ===== Tags ===== */
.card-tags {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.chip {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
}

.category-chip {
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 500;
}

.price-chip {
  background: var(--warning-subtle);
  color: #E6A23C;
  font-weight: 500;
}

/* ===== Meta ===== */
.card-meta {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.meta-location {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meta-icon {
  font-size: 20rpx;
}

.meta-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 280rpx;
}

.card-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== Reason Preview ===== */
.card-reason {
  padding: 0 var(--space-md) var(--space-md);
}

.reason-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-style: italic;
  padding-left: var(--space-sm);
  border-left: 4rpx solid var(--primary-light);
}

/* ===== Reject Section ===== */
.reject-section {
  margin: 0 var(--space-md);
  padding: var(--space-md);
  background: var(--danger-subtle);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-md);
}

.reject-header {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-xs);
}

.reject-icon {
  font-size: 24rpx;
}

.reject-title {
  font-size: 24rpx;
  color: var(--danger);
  font-weight: 600;
}

.reject-reason {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--space-sm);
  display: block;
}

.resubmit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-gradient-deep);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  border: none;
  text-align: center;
  margin: 0;
  padding: 0;
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.2);
}

.resubmit-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.resubmit-btn::after {
  border: none;
}

.resubmit-icon {
  font-size: 24rpx;
}

/* ===== Action Bar ===== */
.card-action-bar {
  padding: 0 var(--space-md) var(--space-md);
}

.action-link {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--space-2xs);
  padding: var(--space-xs) 0;
}

.action-link-text {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.action-link-arrow {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 300;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx var(--space-xl) 0;
}

.empty-illustration {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-lg);
}

.empty-emoji {
  font-size: 96rpx;
  z-index: 1;
}

.empty-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.circle-1 {
  width: 180rpx;
  height: 180rpx;
  background: var(--primary);
  top: 10rpx;
  left: 10rpx;
  animation: float-circle 3s ease-in-out infinite;
}

.circle-2 {
  width: 120rpx;
  height: 120rpx;
  background: var(--primary);
  bottom: 0;
  right: 0;
  animation: float-circle 3s ease-in-out infinite 1s;
}

@keyframes float-circle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: var(--space-xs);
}

.empty-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  line-height: 1.5;
  margin-bottom: var(--space-xl);
}

.empty-btn {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-xl);
  background: var(--primary-gradient-deep);
  border-radius: var(--radius-full);
  box-shadow: var(--primary-glow);
  transition: all var(--anim-fast) ease;
}

.empty-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.empty-btn-icon {
  font-size: 28rpx;
}

.empty-btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* ===== Loading ===== */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) 0;
  gap: var(--space-sm);
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== No More ===== */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-xl) var(--space-xl);
  gap: var(--space-sm);
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}
