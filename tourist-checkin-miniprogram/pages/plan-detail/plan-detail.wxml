<view class="page-container" wx:if="{{plan}}">
  <view class="plan-header">
    <text class="plan-title">{{plan.title}}</text>
    <text class="plan-desc" wx:if="{{plan.description}}">{{plan.description}}</text>
    <view class="plan-meta">
      <text class="meta-item">{{plan.city}}</text>
      <text class="meta-item">{{plan.startDate}} ~ {{plan.endDate}}</text>
      <text class="meta-item">共{{plan.totalDays}}天</text>
    </view>
  </view>

  <view class="map-area">
    <map
      longitude="{{mapLng}}"
      latitude="{{mapLat}}"
      markers="{{markers}}"
      style="width:100%;height:400rpx"
    ></map>
  </view>

  <view class="days-section">
    <view wx:for="{{plan.days}}" wx:key="dayIndex" class="day-block">
      <view class="day-header">
        <text class="day-label">第{{item.dayIndex + 1}}天</text>
      </view>
      <view wx:for="{{item.pois}}" wx:for-item="poi" wx:key="name" class="poi-item">
        <view class="poi-dot"></view>
        <text class="poi-name">{{poi.name}}</text>
      </view>
      <view wx:if="{{item.pois.length === 0}}" class="empty-poi">
        <text>暂无地点安排</text>
      </view>
    </view>
  </view>
</view>

<view wx:if="{{loading}}" class="loading-state">
  <text>加载中...</text>
</view>
