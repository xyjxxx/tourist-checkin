.page-container { min-height: 100vh; background: linear-gradient(180deg, var(--primary-light) 0%, var(--bg) 50%); display: flex; align-items: center; justify-content: center; padding: var(--space-xl); padding-bottom: env(safe-area-inset-bottom); }
.form-card { width: 100%; background: var(--white); border-radius: var(--radius-xl); padding: var(--space-xl); box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.06); }
.form-title { font-size: 40rpx; font-weight: 700; color: var(--text); display: block; text-align: center; margin-bottom: var(--space-12); }
.form-desc { font-size: 26rpx; color: var(--text-secondary); display: block; text-align: center; margin-bottom: 40rpx; }
.input-group { margin-bottom: var(--space-md); }
.input-wrapper { display: flex; align-items: center; height: 96rpx; background: var(--bg); border-radius: 48rpx; padding: 0 var(--space-lg); gap: var(--space-sm); }
.input-prefix { font-size: 32rpx; }
.input-field { flex: 1; font-size: 28rpx; color: var(--text); }
.submit-btn { width: 100%; height: 96rpx; background: var(--primary-gradient-deep); color: var(--white); font-size: 32rpx; font-weight: 700; border-radius: 48rpx; border: none; margin-top: var(--space-lg); display: flex; align-items: center; justify-content: center; }
.submit-btn::after { border: none; }
.back-link { text-align: center; margin-top: var(--space-lg); font-size: 26rpx; color: var(--primary); }
.code-row { display: flex; gap: var(--space-sm); align-items: center; }
.code-input { flex: 1; }
.code-btn { flex-shrink: 0; height: 96rpx; line-height: 96rpx; padding: 0 var(--space-md); font-size: 26rpx; font-weight: 600; color: var(--primary); background: var(--primary-light); border-radius: 48rpx; border: none; }
.code-btn::after { border: none; }
.code-btn[disabled] { color: var(--text-tertiary); background: var(--bg); opacity: 1; }
