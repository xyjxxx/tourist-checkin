<view class="page-container">
  <view class="form-card">
    <text class="form-title">找回密码</text>
    <text class="form-desc">请输入您的账号和注册邮箱</text>
    <view class="input-group">
      <view class="input-wrapper">
        <text class="input-prefix">👤</text>
        <input class="input-field" placeholder="请输入账号" value="{{account}}" bindinput="onAccountInput" />
      </view>
    </view>
    <view class="input-group">
      <view class="input-wrapper">
        <text class="input-prefix">📧</text>
        <input class="input-field" placeholder="请输入注册邮箱" value="{{email}}" bindinput="onEmailInput" />
      </view>
    </view>
    <view class="input-group">
      <view class="code-row">
        <view class="input-wrapper code-input">
          <text class="input-prefix">🔑</text>
          <input class="input-field" placeholder="请输入验证码" value="{{code}}" bindinput="onCodeInput" maxlength="6" />
        </view>
        <button class="code-btn" bindtap="onSendCode" disabled="{{codeCooldown > 0 || sendingCode}}">
          {{codeCooldown > 0 ? codeCooldown + 's' : '发送验证码'}}
        </button>
      </view>
    </view>
    <view class="input-group">
      <view class="input-wrapper">
        <text class="input-prefix">🔒</text>
        <input class="input-field" placeholder="请输入新密码（至少6位）" password value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>
    </view>
    <button class="submit-btn" bindtap="onSubmit" loading="{{loading}}" disabled="{{loading}}">重置密码</button>
    <view class="back-link" bindtap="onBack">
      <text>返回登录</text>
    </view>
  </view>
</view>
