.page-container { background-color: var(--bg); min-height: 100vh; }
.search-bar { display: flex; align-items: center; padding: var(--space-sm) var(--space-md); background: var(--white); gap: var(--space-sm); }
.search-input-wrap { flex: 1; display: flex; align-items: center; height: 72rpx; background: var(--bg); border-radius: 36rpx; padding: 0 var(--space-md); gap: var(--space-12); }
.search-icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.clear-btn { font-size: 28rpx; color: var(--text-tertiary); padding: var(--space-xs); }
.cancel-btn { font-size: 28rpx; color: var(--primary); font-weight: 500; }
.section { background: var(--white); margin: var(--space-sm) var(--space-md); border-radius: 20rpx; padding: var(--space-md); }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-sm); }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: var(--space-sm); display: block; }
.clear-history { font-size: 24rpx; color: var(--text-tertiary); }
.history-tags { display: flex; flex-wrap: wrap; gap: var(--space-12); }
.history-tag { font-size: 24rpx; color: var(--text); background: var(--bg); padding: 10rpx var(--space-md); border-radius: var(--radius-full); }
.note-item { display: flex; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--bg); gap: var(--space-sm); }
.note-item:last-child { border-bottom: none; }
.note-cover { width: 120rpx; height: 90rpx; border-radius: var(--radius-md); flex-shrink: 0; }
.note-info { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: var(--space-xs); }
.note-title { font-size: 28rpx; font-weight: 500; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.note-author { font-size: 22rpx; color: var(--text-secondary); }
.user-item { display: flex; align-items: center; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--bg); gap: var(--space-sm); }
.user-item:last-child { border-bottom: none; }
.user-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0; }
.user-name { font-size: 28rpx; color: var(--text); font-weight: 500; }
.topic-item { display: flex; align-items: center; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--bg); gap: var(--space-xs); }
.topic-item:last-child { border-bottom: none; }
.topic-hash { font-size: 28rpx; color: var(--primary); font-weight: 700; }
.topic-name { font-size: 28rpx; color: var(--text); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; opacity: 0.4; margin-bottom: var(--space-sm); }
.empty-text { font-size: 28rpx; color: var(--text-tertiary); }
