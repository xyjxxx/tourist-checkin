.page-container { background-color: var(--bg); min-height: 100vh; display: flex; flex-direction: column; align-items: center; padding: var(--space-lg); padding-bottom: env(safe-area-inset-bottom); }
.poster-preview { width: 100%; border-radius: 20rpx; overflow: hidden; box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.1); margin-bottom: var(--space-lg); }
.poster-image { width: 100%; min-height: 600rpx; }
.empty-state { padding: 200rpx 0; color: var(--text-tertiary); }
.loading-state { padding: 200rpx 0; color: var(--text-secondary); }
.action-row { width: 100%; display: flex; flex-direction: column; gap: var(--space-20); }
.share-btn { width: 100%; height: 88rpx; background: var(--primary-gradient-deep); color: var(--white); font-size: 30rpx; font-weight: 600; border-radius: 44rpx; border: none; }
.share-btn::after { border: none; }
.save-btn { width: 100%; height: 88rpx; background: var(--white); color: var(--primary); font-size: 30rpx; font-weight: 600; border-radius: 44rpx; border: 2rpx solid var(--primary); }
.save-btn::after { border: none; }
