<view class="page-container">

  <!-- ====== 关注动态 Feed ====== -->
  <block wx:if="{{!showNotes}}">

    <!-- 未登录提示 -->
    <view wx:if="{{!isLoggedIn}}" class="login-banner anim-fade-in-up" bindtap="onGoLogin">
      <view class="banner-left">
        <text class="banner-icon">🔐</text>
        <text class="banner-text">登录后查看关注的人的动态</text>
      </view>
      <text class="banner-btn">去登录</text>
    </view>

    <!-- Skeleton loading -->
    <view wx:if="{{loading && checkinList.length === 0}}" class="skeleton-container">
      <view wx:for="{{3}}" wx:key="index" class="skeleton-card">
        <view class="skeleton-header">
          <view class="skeleton-avatar"></view>
          <view class="skeleton-header-info">
            <view class="skeleton-line skeleton-line-medium"></view>
            <view class="skeleton-line skeleton-line-short"></view>
          </view>
        </view>
        <view class="skeleton-line skeleton-line-long"></view>
        <view class="skeleton-line skeleton-line-short"></view>
        <view class="skeleton-image"></view>
      </view>
    </view>

    <block wx:if="{{!loading || checkinList.length > 0}}">
      <view wx:if="{{refreshing}}" class="refresh-indicator">
        <view class="refresh-dot"></view>
        <text class="refresh-text">正在刷新...</text>
      </view>

      <block wx:if="{{checkinList.length > 0}}">
        <view class="feed-list">
          <view wx:for="{{checkinList}}" wx:key="id" class="checkin-card anim-fade-in-up anim-delay-{{index < 10 ? index + 1 : 10}}"
                bindtap="onTapCard" bindlongpress="onLongPressCheckin" data-id="{{item.id}}" data-userid="{{item.userId}}">
            <!-- Header -->
            <view class="checkin-header">
              <image class="checkin-avatar" src="{{item.avatar}}" mode="aspectFill" bindtap="onTapUser" data-userid="{{item.userId}}"></image>
              <view class="header-info">
                <text class="username" bindtap="onTapUser" data-userid="{{item.userId}}">{{item.username}}</text>
                <view class="location-row" wx:if="{{item.locationName}}">
                  <text class="location-icon-sm">📍</text>
                  <text class="location-name">{{item.locationName}}</text>
                </view>
              </view>
              <text class="checkin-time">{{item.timeText}}</text>
            </view>

            <!-- Content -->
            <view class="checkin-content" wx:if="{{item.content}}">
              <text class="content-text">{{item.content}}</text>
            </view>

            <!-- Images -->
            <view class="image-grid" wx:if="{{item.images && item.images.length > 0}}"
                  style="grid-template-columns: {{item.images.length === 1 ? '1fr' : (item.images.length === 2 ? '1fr 1fr' : (item.images.length === 4 ? '1fr 1fr' : '1fr 1fr 1fr'))}}">
              <view wx:for="{{item.images}}" wx:for-item="img" wx:key="*this" class="image-item"
                    style="aspect-ratio: {{item.images.length === 1 ? '4/3' : '1'}}">
                <image src="{{img}}" mode="aspectFill" class="grid-image"></image>
              </view>
            </view>

            <!-- Actions -->
            <view class="checkin-footer">
              <view class="action-item {{item.isLiked ? 'action-liked' : ''}} {{item.likeAnimating ? 'anim-like-bounce' : ''}}" catchtap="onLikeCheckin" data-id="{{item.id}}">
                <text class="action-icon">{{item.isLiked ? '❤️' : '🤍'}}</text>
                <text class="action-count">{{item.likeCount || 0}}</text>
              </view>
              <view class="action-item" data-id="{{item.id}}">
                <text class="action-icon">💬</text>
                <text class="action-count">{{item.commentCount || 0}}</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- Empty state -->
      <view wx:if="{{!loading && checkinList.length === 0}}" class="empty-state anim-fade-in-scale">
        <text class="empty-emoji">👥</text>
        <text class="empty-title">还没有关注的动态</text>
        <text class="empty-subtitle">去发现更多精彩用户吧</text>
      </view>

      <!-- Loading more -->
      <view wx:if="{{loading && checkinList.length > 0}}" class="loading-more">
        <view class="loading-spinner"></view>
        <text class="loading-text">加载中...</text>
      </view>

      <view wx:if="{{!hasMore && checkinList.length > 0}}" class="no-more">
        <view class="no-more-line"></view>
        <text class="no-more-text">已经到底啦</text>
        <view class="no-more-line"></view>
      </view>
    </block>
  </block>

  <!-- ====== 热门游记列表页 (showNotes 模式) ====== -->
  <block wx:if="{{showNotes}}">
    <!-- 顶部导航 -->
    <view class="top-bar anim-fade-in-down">
      <view class="back-btn" bindtap="onBackToList">
        <text class="back-arrow">‹</text>
        <text class="back-text">返回</text>
      </view>
      <text class="top-title">热门游记</text>
      <view class="top-placeholder"></view>
    </view>

    <!-- 统计 Banner -->
    <view class="stats-banner">
      <view class="banner-bg-shape banner-shape-1"></view>
      <view class="banner-bg-shape banner-shape-2"></view>
      <view class="banner-content">
        <view class="banner-stats">
          <view class="stat-item">
            <text class="stat-num">{{noteStats.total}}</text>
            <text class="stat-label">热门游记</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{noteStats.today}}</text>
            <text class="stat-label">今日新增</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-num">{{noteStats.week}}</text>
            <text class="stat-label">本周上榜</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 排序 + 时间筛选 -->
    <view class="toolbar">
      <view class="sort-tabs">
        <view class="sort-tab {{sortTab === 'hot' ? 'active' : ''}}" bindtap="onTapSort" data-tab="hot">
          <text>🔥 最热</text>
        </view>
        <view class="sort-tab {{sortTab === 'new' ? 'active' : ''}}" bindtap="onTapSort" data-tab="new">
          <text>🕐 最新</text>
        </view>
      </view>
      <scroll-view scroll-x class="time-scroll" enhanced show-scrollbar="{{false}}">
        <view wx:for="{{timeTabs}}" wx:key="*this" class="time-chip {{activeTime === item ? 'active' : ''}}" bindtap="onTapTime" data-tab="{{item}}">
          <text>{{item}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- Loading -->
    <view wx:if="{{loading && noteList.length === 0}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 游记列表 -->
    <view wx:if="{{noteList.length > 0}}" class="feed">
      <view wx:for="{{noteList}}" wx:key="id" id="card-{{index}}"
            class="note-card anim-fade-in-up anim-delay-{{index < 10 ? index + 1 : 10}}"
            bindtap="onOpenPopup" data-id="{{item.id}}" data-index="{{index}}">
        <!-- 排名角标 -->
        <view class="rank-badge rank-{{item.rank <= 3 ? item.rank : 'normal'}}" wx:if="{{item.rank <= 10}}">
          <text class="rank-num">{{item.rank}}</text>
        </view>
        <!-- 封面图 -->
        <view class="note-cover-wrap" wx:if="{{item.coverImage}}">
          <image class="note-cover" src="{{item.coverImage}}" mode="aspectFill"></image>
          <view class="cover-overlay">
            <view class="cover-stats">
              <text class="cover-stat">❤️ {{item.likeCount || 0}}</text>
              <text class="cover-stat">👁 {{item.viewCount || 0}}</text>
            </view>
          </view>
        </view>
        <!-- 内容区 -->
        <view class="note-body">
          <text class="note-title">{{item.title}}</text>
          <text class="note-summary" wx:if="{{item.summary}}">{{item.summary}}</text>
          <view class="note-footer">
            <view class="note-author">
              <image class="author-avatar" src="{{item.author.avatar}}" mode="aspectFill"></image>
              <text class="author-name">{{item.author.username}}</text>
            </view>
            <view class="note-meta-right">
              <text class="note-city" wx:if="{{item.city}}">📍 {{item.city}}</text>
              <text class="note-time">{{item.timeText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && noteList.length === 0}}" class="empty-state">
      <text class="empty-emoji">📝</text>
      <text class="empty-title">暂无热门游记</text>
      <text class="empty-desc">去撰写精彩游记，冲上热榜吧</text>
    </view>

    <!-- 底部提示 -->
    <view wx:if="{{!loading && noteList.length > 0}}" class="footer-tip">
      <view class="footer-line"></view>
      <text class="footer-text">已展示全部热门游记</text>
      <view class="footer-line"></view>
    </view>
  </block>

  <!-- ====== 游记详情弹窗 ====== -->
  <view wx:if="{{popup.show}}" class="popup-mask {{popup.closing ? 'mask-out' : ''}}" bindtap="onClosePopup">
    <view class="popup-card {{popup.closing ? 'closing' : 'opening'}}" style="{{popup.cardStyle}}" catchtap="noop">
      <!-- 弹窗头部 -->
      <view class="popup-header">
        <image class="popup-avatar" src="{{popup.note.author.avatar}}" mode="aspectFill"></image>
        <view class="popup-header-info">
          <text class="popup-username">{{popup.note.author.username}}</text>
          <view class="popup-location" wx:if="{{popup.note.city}}">
            <text>📍</text><text>{{popup.note.city}}</text>
          </view>
        </view>
        <text class="popup-time">{{popup.note.timeText}}</text>
      </view>
      <!-- 弹窗内容 -->
      <scroll-view scroll-y class="popup-scroll" enhanced show-scrollbar="{{false}}">
        <view class="popup-title-area">
          <text class="popup-title-text">{{popup.note.title}}</text>
        </view>
        <view class="popup-content" wx:if="{{popup.note.summary}}">
          <text class="popup-text">{{popup.note.summary}}</text>
        </view>
        <view class="popup-images" wx:if="{{popup.note.coverImage}}">
          <image src="{{popup.note.coverImage}}" mode="widthFix" class="popup-img"
                 bindtap="onPreviewPopupImage" data-src="{{popup.note.coverImage}}"></image>
        </view>
        <!-- 互动区 -->
        <view class="popup-actions">
          <view class="popup-action {{popup.liked ? 'liked' : ''}} {{popup.likeAnimating ? 'anim-like-bounce' : ''}}" bindtap="onPopupLike">
            <text class="action-icon">{{popup.liked ? '❤️' : '🤍'}}</text>
            <text class="popup-action-count">{{popup.likeCount || 0}}</text>
          </view>
          <view class="popup-action">
            <text class="action-icon">💬</text>
            <text class="popup-action-count">{{popup.commentCount || 0}}</text>
          </view>
        </view>
        <!-- 评论区 -->
        <view class="popup-comments">
          <text class="popup-section-title">评论 ({{popup.comments.length}})</text>
          <view wx:if="{{popup.comments.length === 0}}" class="popup-empty">
            <text class="popup-empty-emoji">💬</text>
            <text class="popup-empty-text">暂无评论，快来抢沙发~</text>
          </view>
          <view wx:for="{{popup.comments}}" wx:key="id" class="popup-comment-item">
            <view class="popup-comment-head">
              <text class="popup-comment-user">{{item.username}}</text>
              <text class="popup-comment-time">{{item.timeText}}</text>
            </view>
            <text class="popup-comment-body">{{item.content}}</text>
          </view>
        </view>
        <view style="height: 120rpx;"></view>
      </scroll-view>
      <!-- 评论输入 -->
      <view class="popup-input-bar">
        <view class="popup-input-wrap">
          <input class="popup-input" placeholder="写评论..." value="{{popup.commentText}}"
                 bindinput="onPopupCommentInput" bindconfirm="onPopupSendComment" confirm-type="send" />
        </view>
        <view class="popup-send-btn {{popup.commentText ? 'active' : ''}}" bindtap="onPopupSendComment">发送</view>
      </view>
    </view>
  </view>
</view>
