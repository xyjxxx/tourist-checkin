.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.tabs {
  display: flex;
  flex-direction: row;
  background-color: var(--white);
  padding: 0 var(--space-md);
  border-bottom: 1rpx solid var(--bg);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: var(--space-xl);
  height: 4rpx;
  background-color: var(--primary);
  border-radius: 2rpx;
}

.user-list {
  background-color: var(--white);
}

.user-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--space-20) var(--space-md);
  border-bottom: 1rpx solid var(--bg);
  min-height: 88rpx;
}

.user-item:last-child {
  border-bottom: none;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.follow-btn {
  padding: 10rpx var(--space-md);
  border-radius: var(--radius-xl);
  background-color: var(--primary);
  flex-shrink: 0;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.follow-btn text {
  font-size: 24rpx;
  color: var(--white);
}

.follow-btn.following {
  background-color: var(--bg);
}

.follow-btn.following text {
  color: var(--text-secondary);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}
