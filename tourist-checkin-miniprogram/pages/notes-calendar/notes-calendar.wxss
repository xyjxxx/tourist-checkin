.page-container { background-color: var(--bg); min-height: 100vh; }
.summary-card { display: flex; background: var(--primary-gradient); margin: var(--space-md); padding: 36rpx; border-radius: var(--radius-xl); color: var(--white); }
.summary-item { flex: 1; text-align: center; }
.summary-value { font-size: 44rpx; font-weight: 700; display: block; }
.summary-label { font-size: 22rpx; opacity: 0.9; }
.summary-divider { width: 1rpx; background: rgba(255,255,255,0.3); }
.month-nav { display: flex; align-items: center; justify-content: center; padding: var(--space-20); gap: 40rpx; }
.nav-arrow { font-size: 40rpx; color: var(--text); padding: var(--space-xs) var(--space-20); }
.month-title { font-size: 32rpx; font-weight: 600; color: var(--text); }
.calendar { background: var(--white); margin: 0 var(--space-md); border-radius: var(--radius-xl); padding: var(--space-20); box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.weekday-row { display: flex; margin-bottom: var(--space-12); }
.weekday-cell { flex: 1; text-align: center; font-size: 22rpx; color: var(--text-secondary); font-weight: 500; padding: var(--space-xs) 0; }
.days-grid { display: flex; flex-wrap: wrap; }
.day-cell { width: 14.28%; display: flex; flex-direction: column; align-items: center; padding: var(--space-12) 0; position: relative; }
.day-num { font-size: 26rpx; color: var(--text); }
.other-month .day-num { color: #D1D1D6; }
.checked { background: var(--primary-light); border-radius: var(--radius-md); }
.checked .day-num { color: var(--primary); font-weight: 600; }
.today { border: 2rpx solid var(--primary); border-radius: var(--radius-md); }
.check-dot { width: var(--space-xs); height: var(--space-xs); border-radius: 50%; background: var(--primary); margin-top: 4rpx; }
.month-list { background: var(--white); margin: var(--space-md); border-radius: var(--radius-xl); padding: var(--space-md); }
.list-title { font-size: 28rpx; font-weight: 600; color: var(--text); margin-bottom: var(--space-sm); display: block; }
.checkin-item { display: flex; padding: var(--space-sm) 0; border-bottom: 1rpx solid var(--bg); gap: var(--space-20); }
.checkin-item:last-child { border-bottom: none; }
.checkin-date { width: 80rpx; text-align: center; flex-shrink: 0; }
.date-day { font-size: 36rpx; font-weight: 700; color: var(--primary); display: block; }
.date-weekday { font-size: 20rpx; color: var(--text-secondary); }
.checkin-info { flex: 1; min-width: 0; }
.checkin-content { font-size: 26rpx; color: var(--text); display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; margin-bottom: 4rpx; }
.checkin-location { font-size: 22rpx; color: var(--text-secondary); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 120rpx; }
.empty-icon { font-size: 80rpx; opacity: 0.4; margin-bottom: var(--space-sm); }
.empty-text { font-size: 28rpx; color: var(--text-tertiary); }
.loading-more { text-align: center; padding: var(--space-xl) 0; color: var(--text-secondary); }
