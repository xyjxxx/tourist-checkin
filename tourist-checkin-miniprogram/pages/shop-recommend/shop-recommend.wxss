.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ===== Header Banner ===== */
.header-banner {
  background: var(--primary-gradient-deep);
  padding: var(--space-lg) var(--space-md);
  margin: var(--space-md);
  border-radius: var(--radius-xl);
  box-shadow: var(--primary-glow);
}

.banner-content {
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.banner-icon {
  font-size: 56rpx;
}

.banner-text-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== Form Card ===== */
.form-card {
  background: var(--white);
  margin: var(--space-md) var(--space-md) 0;
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.optional-card {
  border: 2rpx dashed var(--border);
  box-shadow: none;
}

/* ===== Form Group ===== */
.form-group {
  padding: var(--space-xs) 0;
}

.form-label {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.label-icon {
  font-size: 28rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.required {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
  display: block;
}

.form-divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--space-sm) 0;
}

/* ===== Input ===== */
.input-wrap {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-sm) var(--space-md);
  transition: all var(--anim-fast) ease;
}

.input-wrap:focus-within {
  background: var(--primary-subtle);
  box-shadow: 0 0 0 2rpx var(--primary);
}

.form-input {
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ===== Location Card ===== */
.location-card {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  transition: all var(--anim-fast) ease;
}

.location-card.has-value {
  background: var(--primary-subtle);
}

.location-row {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.location-pin {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all var(--anim-fast) ease;
}

.location-pin.active {
  background: var(--primary-light);
}

.pin-icon {
  font-size: 28rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.location-text {
  font-size: 28rpx;
  color: var(--text);
}

.location-text.placeholder {
  color: var(--text-tertiary);
}

.location-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.location-arrow {
  font-size: 36rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}

.map-preview {
  width: 100%;
  height: 200rpx;
  border-radius: var(--radius-md);
  margin-top: var(--space-sm);
}

/* ===== Category Chips ===== */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.category-chip {
  padding: var(--space-12) var(--space-md);
  border-radius: var(--radius-full);
  background: var(--bg);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all var(--anim-fast) var(--ease-out);
  border: 2rpx solid transparent;
}

.category-chip.active {
  background: var(--primary-light);
  color: var(--primary);
  border-color: var(--primary);
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.15);
}

.category-chip:active {
  transform: scale(0.95);
}

/* ===== Price Input ===== */
.price-input-wrap {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-sm) var(--space-md);
  gap: var(--space-xs);
}

.price-symbol {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary);
}

.price-input {
  flex: 1;
  background: transparent;
  padding: 0;
}

.price-unit {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ===== Image Grid ===== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
}

.thumb {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 40%);
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.delete-icon {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.add-btn {
  background: var(--bg);
  border: 3rpx dashed var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.add-btn:active {
  border-color: var(--primary);
  background: var(--primary-subtle);
}

.add-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
}

.add-icon {
  font-size: 52rpx;
  color: var(--text-tertiary);
  line-height: 1;
  font-weight: 300;
}

.add-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== Image Progress ===== */
.image-progress {
  margin-top: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: var(--bg-secondary);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary-gradient);
  border-radius: 4rpx;
  transition: width var(--anim-normal) var(--ease-out);
}

.image-count {
  font-size: 22rpx;
  flex-shrink: 0;
}

.image-count.warn {
  color: var(--danger);
}

.image-count.ok {
  color: var(--success);
}

/* ===== Textarea ===== */
.textarea-wrap {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  transition: all var(--anim-fast) ease;
  border: 2rpx solid transparent;
}

.textarea-wrap.focus {
  background: var(--primary-subtle);
  border-color: rgba(251, 114, 153, 0.2);
}

.form-textarea {
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
  min-height: 180rpx;
  line-height: 1.7;
}

.textarea-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-sm);
  gap: var(--space-sm);
}

.char-meter {
  flex: 1;
}

.meter-track {
  height: 6rpx;
  background: var(--bg-secondary);
  border-radius: 3rpx;
  overflow: hidden;
}

.meter-fill {
  height: 100%;
  background: var(--danger);
  border-radius: 3rpx;
  transition: width var(--anim-normal) var(--ease-out);
}

.meter-fill.valid {
  background: var(--success);
}

.char-count {
  font-size: 22rpx;
  flex-shrink: 0;
}

.char-count.warn {
  color: var(--danger);
}

.char-count.ok {
  color: var(--success);
}

/* ===== Section Header ===== */
.section-header {
  margin: var(--space-xl) var(--space-md) var(--space-sm);
  padding-left: var(--space-xs);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
  display: block;
}

/* ===== Submit Button ===== */
.submit-area {
  padding: var(--space-xl) var(--space-md) 0;
  text-align: center;
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: var(--primary-gradient-deep);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-full);
  border: none;
  text-align: center;
  box-shadow: var(--primary-glow);
  transition: all var(--anim-fast) ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.25);
}

.submit-btn.loading {
  opacity: 0.8;
}

.submit-btn::after {
  border: none;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.btn-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.submit-tip {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: var(--space-sm);
  display: block;
}

/* ===== POI Search Modal ===== */
.poi-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.poi-modal {
  width: 100%;
  height: 75vh;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poi-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}

.poi-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.poi-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.poi-search-bar {
  display: flex;
  align-items: center;
  margin: 0 32rpx 16rpx;
  padding: 16rpx 24rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  gap: 12rpx;
}

.poi-search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.poi-search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.poi-result-list {
  flex: 1;
  padding: 0 32rpx;
}

.poi-loading, .poi-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.poi-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.poi-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.poi-item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.poi-item-addr {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.poi-item-arrow {
  font-size: 32rpx;
  color: #ccc;
  padding-left: 16rpx;
}
