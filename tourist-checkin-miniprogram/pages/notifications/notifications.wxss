.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.header-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-20) var(--space-md);
  background-color: var(--white);
  border-bottom: 1rpx solid var(--bg);
  min-height: 88rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.read-all-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: var(--space-xs) var(--space-sm);
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.notification-list {
  background-color: var(--white);
}

.notification-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--space-md);
  border-bottom: 1rpx solid var(--bg);
  min-height: 88rpx;
}

.notification-item.unread {
  background-color: #FFF8FA;
}

.notif-icon-area {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background-color: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-sm);
  flex-shrink: 0;
}

.notif-icon {
  font-size: 32rpx;
}

.notif-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.notif-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.4;
  margin-bottom: var(--space-xs);
}

.notif-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.unread-dot {
  width: var(--space-12);
  height: var(--space-12);
  border-radius: 6rpx;
  background-color: var(--primary);
  flex-shrink: 0;
  margin-left: var(--space-12);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.no-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 24rpx;
  color: var(--text-secondary);
}
