.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

/* ===== Header Banner ===== */
.header-banner {
  position: relative;
  margin: var(--space-md);
  padding: var(--space-lg) var(--space-md);
  border-radius: var(--radius-2xl);
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.banner-bg-shape {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.shape-1 {
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.12);
  top: -60rpx;
  right: -30rpx;
}

.shape-2 {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.08);
  bottom: -40rpx;
  left: 60rpx;
}

.banner-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: var(--space-md);
}

.banner-icon {
  font-size: 56rpx;
}

.banner-text-wrap {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.banner-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.banner-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* ===== Form Card ===== */
.form-card {
  background: var(--white);
  margin: var(--space-md) var(--space-md) 0;
  border-radius: var(--radius-xl);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
}

.form-group {
  padding: var(--space-xs) 0;
}

.form-divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--space-sm) 0;
}

.form-label {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-sm);
}

.label-icon {
  font-size: 28rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.required {
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 700;
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: var(--space-sm);
  display: block;
}

.input-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: right;
  margin-top: var(--space-xs);
}

/* ===== Input ===== */
.input-wrap {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-sm) var(--space-md);
  transition: all var(--anim-fast) ease;
}

.form-input {
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
}

.input-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* ===== Textarea ===== */
.textarea-wrap {
  background: var(--bg);
  border-radius: var(--radius-lg);
  padding: var(--space-md);
  transition: all var(--anim-fast) ease;
  border: 2rpx solid transparent;
}

.textarea-wrap.focus {
  background: rgba(102, 126, 234, 0.04);
  border-color: rgba(102, 126, 234, 0.15);
}

.form-textarea {
  font-size: 28rpx;
  color: var(--text);
  width: 100%;
  min-height: 300rpx;
  line-height: 1.8;
}

.textarea-placeholder {
  color: var(--text-tertiary);
  font-size: 28rpx;
  line-height: 1.8;
}

.textarea-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--space-sm);
  gap: var(--space-sm);
}

.char-meter {
  flex: 1;
}

.meter-track {
  height: 6rpx;
  background: var(--bg-secondary);
  border-radius: 3rpx;
  overflow: hidden;
}

.meter-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 3rpx;
  transition: width var(--anim-normal) var(--ease-out);
  min-width: 0;
}

.char-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

/* ===== Cover Image ===== */
.cover-area {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--bg);
}

.cover-preview {
  width: 100%;
  height: 100%;
}

.cover-add {
  width: 100%;
  height: 100%;
  border: 3rpx dashed var(--border);
  border-radius: var(--radius-xl);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
  transition: all var(--anim-fast) ease;
}

.cover-add:active {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.04);
}

.cover-add-icon {
  font-size: 64rpx;
  color: var(--text-tertiary);
  font-weight: 300;
  line-height: 1;
}

.cover-add-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.cover-add-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--space-sm) 0;
  background: linear-gradient(to top, rgba(0,0,0,0.45), transparent);
  text-align: center;
}

.cover-change-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

/* ===== Tag Preview ===== */
.tag-preview {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-sm);
}

.tag-chip {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1), rgba(118, 75, 162, 0.1));
  color: #667eea;
  font-size: 22rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* ===== Image Grid ===== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  margin-top: var(--space-sm);
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, transparent 40%);
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}

.delete-icon {
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 3rpx dashed var(--border);
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  transition: all var(--anim-fast) ease;
}

.image-add:active {
  border-color: #667eea;
  background: rgba(102, 126, 234, 0.04);
}

.add-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-xs);
}

.add-icon {
  font-size: 52rpx;
  color: var(--text-tertiary);
  line-height: 1;
  font-weight: 300;
}

.add-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== Image Progress ===== */
.image-progress {
  margin-top: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: var(--bg-secondary);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 4rpx;
  transition: width var(--anim-normal) var(--ease-out);
}

.image-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

/* ===== Submit Button ===== */
.submit-area {
  padding: var(--space-xl) var(--space-md) 0;
}

.submit-btn {
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: var(--radius-full);
  border: none;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
  transition: all var(--anim-fast) ease;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.25);
}

.submit-btn.loading {
  opacity: 0.8;
}

.submit-btn::after {
  border: none;
}

.btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-xs);
}

.btn-icon {
  font-size: 32rpx;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.btn-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
