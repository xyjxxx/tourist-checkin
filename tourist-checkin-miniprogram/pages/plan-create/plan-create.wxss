.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.form-area {
  background-color: var(--white);
  padding: var(--space-md);
}

.input-group {
  margin-bottom: var(--space-md);
}

.row-group {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
}

.half-input {
  flex: 1;
}

.label {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  margin-bottom: var(--space-12);
  display: block;
}

.text-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: var(--radius-sm);
  padding: 0 var(--space-sm);
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.content-input {
  width: 100%;
  min-height: 120rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: var(--radius-sm);
  padding: var(--space-sm);
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  box-sizing: border-box;
}

.picker-value {
  height: 80rpx;
  line-height: 80rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: var(--radius-sm);
  padding: 0 var(--space-sm);
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.days-section {
  margin-top: var(--space-sm);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: var(--space-sm);
  display: block;
}

.day-block {
  background-color: #F9FAFB;
  border-radius: var(--radius-md);
  padding: var(--space-20);
  margin-bottom: var(--space-sm);
}

.day-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--space-sm);
}

.day-label {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

.add-poi-btn {
  font-size: 24rpx;
  color: var(--primary);
}

.poi-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--space-12);
}

.poi-input {
  flex: 1;
  height: 72rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: var(--radius-sm);
  padding: 0 var(--space-sm);
  font-size: 26rpx;
  color: var(--text);
  background-color: var(--white);
}

.delete-poi {
  width: 48rpx;
  height: 48rpx;
  text-align: center;
  line-height: 48rpx;
  color: var(--text-secondary);
  font-size: 24rpx;
  margin-left: var(--space-12);
}

.empty-poi {
  text-align: center;
  padding: var(--space-sm) 0;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.add-day-btn {
  text-align: center;
  padding: var(--space-md);
  border: 2rpx dashed var(--primary);
  border-radius: var(--radius-md);
  color: var(--primary);
  font-size: 28rpx;
  margin-top: var(--space-sm);
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-area {
  padding-top: var(--space-lg);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: var(--primary);
  color: var(--white);
  font-size: var(--space-lg);
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background-color: #FBBCC9;
  color: var(--white);
}
