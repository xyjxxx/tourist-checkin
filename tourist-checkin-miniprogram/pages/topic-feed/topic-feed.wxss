.page-container {
  background-color: var(--bg);
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

.topic-header {
  background-color: var(--white);
  padding: var(--space-lg) var(--space-md);
  text-align: center;
  border-bottom: 1rpx solid var(--bg);
}

.topic-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary);
}

.feed-list {
  padding: var(--space-sm) 0;
}

.checkin-item {
  background-color: var(--white);
  margin-bottom: var(--space-sm);
  padding: var(--space-md);
}

.checkin-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--space-20);
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  margin-right: var(--space-sm);
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.location-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.checkin-time {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.checkin-content {
  margin-bottom: var(--space-20);
}

.content-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-20);
}

.image-item {
  width: 218rpx;
  height: 218rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.grid-image {
  width: 100%;
  height: 100%;
}

.checkin-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--bg);
}

.action-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-right: var(--space-xl);
}

.action-icon {
  font-size: 28rpx;
  margin-right: var(--space-xs);
  color: var(--text-secondary);
}

.action-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.loading-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.no-more {
  text-align: center;
  padding: var(--space-md) 0;
  font-size: 24rpx;
  color: var(--text-secondary);
}
