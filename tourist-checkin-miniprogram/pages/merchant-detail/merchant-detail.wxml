<view class="page-container" wx:if="{{merchant}}">
  <image class="merchant-cover" src="{{merchant.image}}" mode="aspectFill"></image>
  <view class="merchant-info">
    <text class="merchant-name">{{merchant.name}}</text>
    <view class="tags-row">
      <text class="category-tag">{{merchant.category}}</text>
      <text class="price-tag" wx:if="{{merchant.priceLevel}}">{{merchant.priceLevel}}</text>
    </view>
    <view class="meta-row" wx:if="{{merchant.rating}}">
      <text class="rating">⭐ {{merchant.rating}}</text>
    </view>
    <view class="info-item" wx:if="{{merchant.address}}">
      <text class="info-icon">📍</text>
      <text class="info-text">{{merchant.address}}</text>
    </view>
    <view class="info-item" wx:if="{{merchant.phone}}">
      <text class="info-icon">📞</text>
      <text class="info-text" bindtap="onCallPhone">{{merchant.phone}}</text>
    </view>
    <view class="info-item" wx:if="{{merchant.businessHours}}">
      <text class="info-icon">🕐</text>
      <text class="info-text">{{merchant.businessHours}}</text>
    </view>
  </view>
  <view class="map-area" wx:if="{{merchant.longitude && merchant.latitude}}">
    <map longitude="{{merchant.longitude}}" latitude="{{merchant.latitude}}" markers="{{markers}}" style="width:100%;height:350rpx" show-location></map>
  </view>
  <view class="action-row">
    <button class="action-btn navigate-btn" bindtap="onNavigate">导航前往</button>
  </view>
</view>
<view wx:if="{{loading}}" class="loading-state"><text>加载中...</text></view>
