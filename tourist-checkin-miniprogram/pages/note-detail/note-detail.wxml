<view class="page-container" wx:if="{{note}}">

  <!-- 封面大图 -->
  <view class="hero-cover" wx:if="{{note.coverImage}}">
    <image class="hero-image" src="{{note.coverImage}}" mode="aspectFill"></image>
    <view class="hero-overlay">
      <view class="hero-tags" wx:if="{{note.city}}">
        <view class="hero-tag">
          <text class="tag-icon">📍</text>
          <text class="tag-text">{{note.city}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 标题区 -->
  <view class="title-section">
    <text class="note-title">{{note.title}}</text>
    <view class="author-row" wx:if="{{note.author}}" bindtap="onTapAuthor" data-userid="{{note.author.id}}">
      <image class="author-avatar" src="{{note.author.avatar}}" mode="aspectFill"></image>
      <view class="author-info">
        <text class="author-name">{{note.author.username}}</text>
        <text class="note-time">{{note.timeText}}</text>
      </view>
    </view>
  </view>

  <!-- 正文 -->
  <view class="content-section">
    <text class="content-text">{{note.content}}</text>
  </view>

  <!-- 图片列表 -->
  <view class="image-section" wx:if="{{note.images && note.images.length > 0}}">
    <view class="image-grid"
          style="grid-template-columns: {{note.images.length === 1 ? '1fr' : (note.images.length === 2 ? '1fr 1fr' : (note.images.length === 4 ? '1fr 1fr' : '1fr 1fr 1fr'))}}">
      <view wx:for="{{note.images}}" wx:key="*this" class="image-item"
            style="aspect-ratio: {{note.images.length === 1 ? '4/3' : '1'}}">
        <image src="{{item}}" mode="aspectFill" class="grid-image" bindtap="onPreviewImage" data-src="{{item}}"></image>
      </view>
    </view>
  </view>

  <!-- 标签 -->
  <view class="tags-section" wx:if="{{note.tags && note.tags.length > 0}}">
    <view class="tag-chip" wx:for="{{note.tags}}" wx:key="*this">
      <text class="chip-hash">#</text>
      <text class="chip-text">{{item}}</text>
    </view>
  </view>

  <!-- 互动统计 -->
  <view class="stats-bar">
    <view class="stats-left">
      <text class="stats-text">👁 {{note.viewCount || 0}} 浏览</text>
      <text class="stats-dot">·</text>
      <text class="stats-text">❤️ {{note.likeCount || 0}} 点赞</text>
    </view>
  </view>

  <!-- 操作栏 -->
  <view class="action-bar">
    <view class="action-btn {{liked ? 'action-liked' : ''}}" bindtap="onLike">
      <text class="action-icon">{{liked ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{note.likeCount || 0}}</text>
    </view>
    <view class="action-btn {{collected ? 'action-collected' : ''}}" bindtap="onCollect">
      <text class="action-icon">{{collected ? '⭐' : '☆'}}</text>
      <text class="action-text">{{collected ? '已收藏' : '收藏'}}</text>
    </view>
    <view class="action-btn" bindtap="onShowCommentInput">
      <text class="action-icon">💬</text>
      <text class="action-text">{{note.commentCount || 0}}</text>
    </view>
    <view class="action-btn" open-type="share">
      <text class="action-icon">📤</text>
      <text class="action-text">分享</text>
    </view>
    <view class="action-btn action-report" bindtap="onReport">
      <text class="action-icon">⚠️</text>
    </view>
  </view>

  <!-- 评论区 -->
  <view class="comment-section">
    <view class="section-header">
      <text class="section-title">评论</text>
      <text class="section-count">{{comments.length}}</text>
    </view>

    <!-- 空评论 -->
    <view wx:if="{{comments.length === 0}}" class="comment-empty">
      <text class="comment-empty-emoji">💬</text>
      <text class="comment-empty-text">暂无评论，快来抢沙发~</text>
    </view>

    <!-- 评论列表 -->
    <view wx:for="{{comments}}" wx:key="id" class="comment-item">
      <image class="comment-avatar" src="{{item.user.avatar || ''}}" mode="aspectFill"></image>
      <view class="comment-body">
        <view class="comment-head">
          <text class="comment-user">{{item.user.username || '匿名用户'}}</text>
          <text class="comment-time">{{item.timeText}}</text>
        </view>
        <text class="comment-content">{{item.content}}</text>
        <view class="comment-actions">
          <view class="comment-action" bindtap="onLikeComment" data-id="{{item.id}}">
            <text>♥ {{item.likeCount || 0}}</text>
          </view>
          <view class="comment-action" bindtap="onReplyComment"
                data-commentid="{{item.id}}" data-userid="{{item.userId}}" data-username="{{item.user.username || '匿名用户'}}">
            <text>回复</text>
          </view>
        </view>
        <!-- 子评论 -->
        <view wx:if="{{item.replies && item.replies.length > 0}}" class="replies">
          <view wx:for="{{item.replies}}" wx:for-item="reply" wx:key="id" class="reply-item">
            <text class="reply-user">{{reply.user.username || '匿名用户'}}</text>
            <text class="reply-content">{{reply.content}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 评论输入框 -->
  <view class="comment-input-bar" wx:if="{{showCommentInput}}">
    <view class="input-mask" bindtap="onCloseCommentInput"></view>
    <view class="input-area">
      <view class="input-wrap">
        <input class="comment-input" placeholder="{{replyingTo ? '回复 ' + replyingTo.username : '写评论...'}}"
               value="{{commentText}}" bindinput="onCommentInput" focus="{{showCommentInput}}" />
      </view>
      <view class="send-btn {{commentText ? 'active' : ''}}" bindtap="onSubmitComment">发送</view>
    </view>
  </view>
</view>

<!-- 加载态 -->
<view wx:if="{{loading}}" class="loading-state">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>
