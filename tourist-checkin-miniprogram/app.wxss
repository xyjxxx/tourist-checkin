page {
  /* ===== Brand Colors ===== */
  --primary: #FB7299;
  --primary-dark: #E85D88;
  --primary-light: #FFF0F3;
  --primary-subtle: #FFF7FA;
  --primary-foreground: #FFFFFF;
  --primary-gradient: linear-gradient(135deg, #FB7299, #FF9AB5);
  --primary-gradient-deep: linear-gradient(135deg, #E85D88, #FB7299, #FFB6C8);
  --primary-glow: 0 8rpx 32rpx rgba(251, 114, 153, 0.3);

  /* ===== Surfaces ===== */
  --bg: #F5F5F7;
  --bg-secondary: #ECECEF;
  --white: #FFFFFF;
  --border: #E8E8ED;
  --border-light: #F5F5F7;

  /* ===== Text ===== */
  --text: #1D1D1F;
  --text-secondary: #86868B;
  --text-tertiary: #AEAEB2;

  /* ===== Status ===== */
  --success: #34C759;
  --success-subtle: #F0FFF4;
  --warning: #FF9500;
  --warning-subtle: #FFF8F0;
  --danger: #FF3B30;
  --danger-subtle: #FFF0F0;
  --info: #8E8E93;
  --info-subtle: #F5F5F7;

  /* ===== Shadows ===== */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  --shadow-card: 0 2rpx 12rpx rgba(0, 0, 0, 0.04), 0 0 2rpx rgba(0, 0, 0, 0.02);
  --shadow-float: 0 12rpx 40rpx rgba(0, 0, 0, 0.1);

  /* ===== Spacing ===== */
  --space-2xs: 4rpx;
  --space-xs: 8rpx;
  --space-12: 12rpx;
  --space-sm: 16rpx;
  --space-20: 20rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;

  /* ===== Radius ===== */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-full: 999rpx;

  /* ===== Animation ===== */
  --anim-fast: 200ms;
  --anim-normal: 300ms;
  --anim-slow: 500ms;
  --anim-decorative: 1200ms;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-in: cubic-bezier(0.7, 0, 0.84, 0);
  --ease-in-out: cubic-bezier(0.45, 0, 0.55, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-spring: cubic-bezier(0.175, 0.885, 0.32, 1.275);

  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background-color: var(--bg);
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ============================================================
   LAYOUT
   ============================================================ */

.container {
  padding: var(--space-md);
}

.card {
  background: var(--white);
  border-radius: var(--radius-xl);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-card);
}

.card-elevated {
  background: var(--white);
  border-radius: var(--radius-xl);
  padding: var(--space-md);
  margin-bottom: var(--space-md);
  box-shadow: var(--shadow-md);
  transition: box-shadow var(--anim-fast) ease, transform var(--anim-fast) ease;
}

.card-elevated:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-sm);
}

/* ============================================================
   TYPOGRAPHY
   ============================================================ */

.text-xs {
  font-size: 20rpx;
  line-height: 1.4;
}

.text-sm {
  font-size: 24rpx;
  line-height: 1.5;
}

.text-base {
  font-size: 28rpx;
  line-height: 1.5;
}

.text-lg {
  font-size: 32rpx;
  line-height: 1.4;
}

.text-xl {
  font-size: 36rpx;
  line-height: 1.3;
}

.text-2xl {
  font-size: 44rpx;
  line-height: 1.2;
}

.text-3xl {
  font-size: 56rpx;
  line-height: 1.1;
}

.font-medium {
  font-weight: 500;
}

.font-semibold {
  font-weight: 600;
}

.font-bold {
  font-weight: 700;
}

.text-primary {
  color: var(--primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-success {
  color: var(--success);
}

.text-warning {
  color: var(--warning);
}

.text-danger {
  color: var(--danger);
}

.text-center {
  text-align: center;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.truncate-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ============================================================
   FLEX
   ============================================================ */

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

.between {
  justify-content: space-between;
}

.center {
  justify-content: center;
  align-items: center;
}

.wrap {
  flex-wrap: wrap;
}

.gap-xs {
  gap: var(--space-xs);
}

.gap-sm {
  gap: var(--space-sm);
}

.gap-md {
  gap: var(--space-md);
}

/* ============================================================
   BUTTONS
   ============================================================ */

.btn-primary {
  background: var(--primary);
  color: var(--primary-foreground);
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.btn-primary:active {
  background: var(--primary-dark);
  transform: scale(0.97);
}

.btn-gradient {
  background: var(--primary-gradient-deep);
  color: var(--primary-foreground);
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.btn-gradient:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn-outline {
  background: transparent;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: var(--radius-full);
  padding: 18rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.btn-outline:active {
  background: var(--primary-light);
  transform: scale(0.97);
}

.btn-ghost {
  background: transparent;
  color: var(--text-secondary);
  border: none;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.btn-ghost:active {
  color: var(--primary);
  background: var(--primary-light);
  border-radius: var(--radius-sm);
}

.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
  border: none;
  border-radius: var(--radius-full);
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  min-height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--anim-fast) ease;
}

.btn-danger:active {
  opacity: 0.85;
  transform: scale(0.97);
}

.btn-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* ============================================================
   AVATAR
   ============================================================ */

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg);
  overflow: hidden;
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-lg {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
}

/* ============================================================
   TAG & BADGE
   ============================================================ */

.tag {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 500;
}

.tag-outline {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-full);
  border: 1rpx solid var(--border);
  color: var(--text-secondary);
}

.tag-success {
  background: var(--success-subtle);
  color: var(--success);
}

.tag-warning {
  background: var(--warning-subtle);
  color: var(--warning);
}

.tag-danger {
  background: var(--danger-subtle);
  color: var(--danger);
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  font-size: 20rpx;
  color: #fff;
  background: var(--danger);
  border-radius: var(--radius-full);
  font-weight: 600;
}

/* ============================================================
   DIVIDER
   ============================================================ */

.divider {
  height: 1rpx;
  background: var(--border-light);
  margin: var(--space-sm) 0;
}

/* ============================================================
   STATES
   ============================================================ */

.empty-tip {
  text-align: center;
  padding: 120rpx var(--space-lg);
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--space-md);
  display: block;
  text-align: center;
  opacity: 0.6;
}

.bg-primary-subtle {
  background: var(--primary-subtle);
}

/* ============================================================
   SKELETON
   ============================================================ */

.skeleton {
  background: linear-gradient(90deg, var(--bg-secondary) 25%, var(--border-light) 50%, var(--bg-secondary) 75%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.5s ease infinite;
  border-radius: var(--radius-sm);
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

/* ============================================================
   SAFE AREA
   ============================================================ */

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============================================================
   TOUCH TARGET
   ============================================================ */

.min-touch-target {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

/* ============================================================
   LOADING
   ============================================================ */

.loading-spinner {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(251, 114, 153, 0.2);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ============================================================
   TOAST
   ============================================================ */

.toast-success {
  background: var(--success);
  color: white;
}

.toast-error {
  background: var(--danger);
  color: white;
}

/* ============================================================
   IMAGE
   ============================================================ */

.img-placeholder {
  background: linear-gradient(135deg, var(--bg), var(--bg-secondary));
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 48rpx;
}

/* ============================================================
   PRESS FEEDBACK
   ============================================================ */

.pressable {
  transition: opacity var(--anim-fast) ease, transform var(--anim-fast) ease;
}

.pressable:active {
  opacity: 0.7;
  transform: scale(0.97);
}

/* ============================================================
   STATUS BAR
   ============================================================ */

.status-bar {
  height: var(--status-bar-height, 44rpx);
}

/* ============================================================
   GRADIENT
   ============================================================ */

.bg-gradient-primary {
  background: var(--primary-gradient);
}

.bg-gradient-deep {
  background: var(--primary-gradient-deep);
}

/* ============================================================
   GLOW EFFECTS (Aurora UI)
   ============================================================ */

.glow-primary {
  box-shadow: var(--primary-glow);
}

/* ============================================================
   SCROLLBAR
   ============================================================ */

::-webkit-scrollbar {
  display: none;
}

/* ============================================================
   ANIMATION SYSTEM
   ============================================================ */

/* --- @keyframes --- */

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fade-in-down {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fade-in-scale {
  from { opacity: 0; transform: scale(0.85); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slide-in-right {
  from { opacity: 0; transform: translateX(60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes slide-in-left {
  from { opacity: 0; transform: translateX(-60rpx); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes slide-up {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes scale-bounce {
  0% { transform: scale(1); }
  30% { transform: scale(1.3); }
  50% { transform: scale(0.9); }
  70% { transform: scale(1.1); }
  100% { transform: scale(1); }
}

@keyframes pop-in {
  0% { opacity: 0; transform: scale(0); }
  60% { opacity: 1; transform: scale(1.1); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes heartbeat {
  0% { transform: scale(1); }
  15% { transform: scale(1.15); }
  30% { transform: scale(1); }
  45% { transform: scale(1.1); }
  60% { transform: scale(1); }
}

@keyframes confetti-fall {
  0% { transform: translateY(-20rpx) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100rpx) rotate(360deg); opacity: 0; }
}

@keyframes shimmer-slide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(251, 114, 153, 0.4); }
  50% { box-shadow: 0 0 20rpx 8rpx rgba(251, 114, 153, 0.2); }
}

@keyframes float-up {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* --- Entrance --- */

.anim-fade-in-up {
  animation: fade-in-up var(--anim-normal) var(--ease-out) both;
}

.anim-fade-in-down {
  animation: fade-in-down var(--anim-normal) var(--ease-out) both;
}

.anim-fade-in-scale {
  animation: fade-in-scale var(--anim-normal) var(--ease-out) both;
}

.anim-slide-in-right {
  animation: slide-in-right var(--anim-normal) var(--ease-out) both;
}

.anim-slide-in-left {
  animation: slide-in-left var(--anim-normal) var(--ease-out) both;
}

.anim-slide-up {
  animation: slide-up var(--anim-slow) var(--ease-out) both;
}

.anim-pop-in {
  animation: pop-in var(--anim-slow) var(--ease-spring) both;
}

/* --- Stagger Delays --- */

.anim-delay-1 { animation-delay: 50ms; }
.anim-delay-2 { animation-delay: 100ms; }
.anim-delay-3 { animation-delay: 150ms; }
.anim-delay-4 { animation-delay: 200ms; }
.anim-delay-5 { animation-delay: 250ms; }
.anim-delay-6 { animation-delay: 300ms; }
.anim-delay-7 { animation-delay: 350ms; }
.anim-delay-8 { animation-delay: 400ms; }
.anim-delay-9 { animation-delay: 450ms; }
.anim-delay-10 { animation-delay: 500ms; }

/* --- Interaction --- */

.anim-like-bounce {
  animation: scale-bounce 400ms var(--ease-bounce);
}

.anim-heartbeat {
  animation: heartbeat 800ms var(--ease-bounce);
}

.anim-pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

.anim-float {
  animation: float-up 3s ease-in-out infinite;
}

/* --- Tab Switch --- */

.anim-tab-enter {
  animation: fade-in-up var(--anim-fast) var(--ease-out) both;
}

.anim-tab-exit {
  animation: fade-in-up var(--anim-fast) var(--ease-out) reverse both;
}

/* --- Scroll Reveal --- */

.anim-reveal {
  opacity: 0;
  transform: translateY(40rpx);
  transition: opacity var(--anim-normal) var(--ease-out),
              transform var(--anim-normal) var(--ease-out);
}

.anim-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* --- Celebration --- */

.anim-celebration {
  animation: pop-in 600ms var(--ease-spring) both,
             heartbeat 800ms var(--ease-bounce) 600ms both;
}

/* --- Reduced Motion --- */

/* ============================================================
   SHARED FEED COMPONENTS
   ============================================================ */

.refresh-indicator {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) 0;
  gap: var(--space-12);
}

.refresh-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.refresh-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.feed-list {
  padding: var(--space-12) 0;
}

.checkin-card {
  background-color: var(--white);
  margin: var(--space-12) var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
  transition: transform var(--anim-fast) ease, box-shadow var(--anim-fast) ease;
}

.checkin-card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.checkin-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: var(--space-20);
}

.checkin-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: var(--space-20);
  background: var(--bg);
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.username {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.location-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-2xs);
}

.location-icon-sm { font-size: 20rpx; }

.location-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.checkin-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-left: var(--space-sm);
}

.checkin-content {
  margin-bottom: var(--space-20);
}

.content-text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.7;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 6;
  overflow: hidden;
}

.image-grid {
  display: grid;
  gap: var(--space-xs);
  margin-bottom: var(--space-20);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.image-item {
  border-radius: var(--radius-md);
  overflow: hidden;
}

.grid-image {
  width: 100%;
  height: 100%;
  display: block;
}

.checkin-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: var(--space-sm);
  border-top: 1rpx solid var(--border-light);
  gap: 40rpx;
}

.action-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-lg);
  min-height: 88rpx;
  transition: all var(--anim-fast) ease;
}

.action-item:active {
  background: var(--bg);
}

.action-liked .action-count {
  color: var(--danger);
}

.action-icon { font-size: 28rpx; }

.action-count {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.skeleton-container { padding: var(--space-12) 0; }

.skeleton-card {
  background: var(--white);
  margin: var(--space-12) var(--space-md);
  padding: var(--space-md);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.skeleton-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--space-md);
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  margin-right: var(--space-20);
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

.skeleton-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.skeleton-line {
  height: 24rpx;
  border-radius: var(--radius-md);
  background: var(--bg-secondary);
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

.skeleton-line-long { width: 80%; }
.skeleton-line-medium { width: 60%; }
.skeleton-line-short { width: 40%; }

.skeleton-image {
  width: 100%;
  height: 300rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-secondary);
  margin-top: var(--space-20);
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

@keyframes skeleton-shimmer {
  0% { opacity: 1; }
  50% { opacity: 0.4; }
  100% { opacity: 1; }
}

/* ============================================================
   SHARED EXPLORE / DISCOVER COMPONENTS
   ============================================================ */

.search-bar {
  padding: var(--space-sm) var(--space-md);
  background-color: var(--white);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-input {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: var(--bg);
  border-radius: 40rpx;
  padding: var(--space-sm) var(--space-md);
  transition: all var(--anim-fast) ease;
}

.search-icon {
  font-size: 28rpx;
  margin-right: var(--space-12);
  opacity: 0.5;
}

.search-placeholder-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.section {
  margin-top: var(--space-sm);
  background-color: var(--white);
  padding: var(--space-md);
}

.section-header {
  margin-bottom: var(--space-20);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text);
}

.note-card {
  display: flex;
  flex-direction: row;
  padding: var(--space-20) 0;
  border-bottom: 1rpx solid var(--border-light);
  transition: all var(--anim-fast) ease;
}

.note-card:last-child {
  border-bottom: none;
}

.note-card:active {
  opacity: 0.7;
}

.note-cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: var(--radius-lg);
  margin-right: var(--space-20);
  background: var(--bg);
}

.note-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.note-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}

.note-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-12);
}

.note-author {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.note-city-tag {
  background: var(--bg);
  padding: 4rpx var(--space-12);
  border-radius: var(--radius-sm);
}

.note-city-text {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.note-stats {
  display: flex;
  flex-direction: row;
  gap: var(--space-md);
}

.note-stat {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-2xs);
}

.stat-icon {
  font-size: 22rpx;
}

.stat-value {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.hot-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xs) 0;
}

.hot-entry-left {
  display: flex;
  align-items: center;
  gap: var(--space-20);
}

.hot-entry-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hot-entry-icon {
  font-size: 36rpx;
}

.hot-entry-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.hot-entry-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.hot-entry-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.hot-entry-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.merchants-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-xs) 0;
}

.merchants-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-20);
}

.merchants-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.merchants-icon {
  font-size: 36rpx;
}

.merchants-info {
  display: flex;
  flex-direction: column;
  gap: var(--space-2xs);
}

.merchants-title {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 600;
}

.merchants-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.merchants-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
}

/* ============================================================
   SHARED EMPTY / LOADING / NO-MORE / FAB
   ============================================================ */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
  gap: var(--space-sm);
}

.empty-emoji { font-size: 96rpx; opacity: 0.5; }

.empty-title {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
}

.empty-subtitle {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.loading-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg) 0;
  gap: var(--space-12);
}

.loading-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.no-more {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: var(--space-lg) var(--space-xl);
  gap: var(--space-sm);
}

.no-more-line {
  flex: 1;
  height: 1rpx;
  background: var(--border);
}

.no-more-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

.fab-recommend {
  position: fixed;
  right: var(--space-lg);
  bottom: 180rpx;
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  background: var(--primary-gradient-deep);
  border-radius: var(--radius-full);
  box-shadow: var(--primary-glow);
  z-index: 100;
  transition: transform var(--anim-fast) ease, box-shadow var(--anim-fast) ease;
}

.fab-recommend:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(251, 114, 153, 0.3);
}

.fab-icon { font-size: 32rpx; }

.fab-text {
  font-size: 24rpx;
  color: var(--primary-foreground);
  font-weight: 600;
}

/* ============================================================
   LOGIN BANNER
   ============================================================ */

.login-banner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FFF0F3, #FFE4EC);
  margin: var(--space-sm) var(--space-md);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-xl);
  border: 1rpx solid rgba(251, 114, 153, 0.15);
}

.login-banner:active {
  opacity: 0.85;
}

.banner-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--space-12);
}

.banner-icon {
  font-size: 32rpx;
}

.banner-text {
  font-size: 26rpx;
  color: var(--text);
  font-weight: 500;
}

.banner-btn {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 700;
  background: var(--white);
  padding: 10rpx 24rpx;
  border-radius: var(--radius-full);
}

/* ============================================================
   REDUCED MOTION
   ============================================================ */

@media (prefers-reduced-motion: reduce) {
  .anim-fade-in-up, .anim-fade-in-down, .anim-fade-in-scale,
  .anim-slide-in-right, .anim-slide-in-left, .anim-slide-up,
  .anim-pop-in, .anim-like-bounce, .anim-heartbeat,
  .anim-tab-enter, .anim-tab-exit, .anim-celebration,
  .anim-reveal, .anim-reveal.is-visible,
  .anim-pulse-glow, .anim-float,
  .pressable, .card-elevated, .btn-primary, .btn-gradient,
  .btn-outline, .btn-ghost, .btn-danger,
  .skeleton, .loading-spinner {
    animation-duration: 0.01ms !important;
    animation-delay: 0ms !important;
    transition-duration: 0.01ms !important;
  }
}
